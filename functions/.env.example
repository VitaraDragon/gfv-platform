# Copia in .secret.local per emulator locale (non committare .secret.local)
# NON mettere OPENWEATHER_API_KEY / RESEND_API_KEY in .env: il deploy le invierebbe
# come env normali e confligono con defineSecret → errore Cloud Run 400.
#
# Produzione:
#   firebase functions:secrets:set RESEND_API_KEY
#   firebase functions:secrets:set OPENWEATHER_API_KEY
#
# Emulator (functions/.secret.local):
#   RESEND_API_KEY=...
#   OPENWEATHER_API_KEY=...
RESEND_API_KEY=
OPENWEATHER_API_KEY=
