      "expect": {
        "latencyMsMax": 3000,
        "responseMustMatch": ["tariff", "attiv"],
        "responseMustNotMatch": ["non ho", "sessione scaduta"]
      }
    },
    {
      "id": "T-PERF-004",
      "status": "ready",
      "mode": "explore",
      "tier": 3,
      "category": "multi_domain",
      "description": "Live CF — domanda multi-dominio meteo+scorte (multi_block quick o Gemini T4)",
      "contract": {
        "invariant": "Domanda multi-dominio → almeno un blocco semantico (meteo OR scorte)",
        "primaryAsserts": ["responseMustMatchGroupsMin >= 1"],
        "avoidAsserts": ["tutti i gruppi obbligatori simultanei"]
      },
      "persona": "manager",
      "startUrl": "/core/dashboard-standalone.html?emulator=1&tonyE2e=1&tonyE2eLive=1",
      "login": "loginAsManagerFromDevPage",
      "messages": ["domani trattamento, ho scorte di concime basse e che meteo c'è?"],
      "mockCf": false,
      "expect": {
        "latencyMsMax": 12000,
        "replyTimeoutMs": 60000,
        "responseMustMatchGroupsMin": 1,
        "responseMustMatchGroups": [
          ["meteo", "tempo", "pioggia", "prevision", "previsioni", "gradi", "nuvol", "vento", "domani", "sole", "sereno", "copert", "clima", "temperatur", "rovesci", "umid", "condizion", "atmosfer", "cielo", "maltempo", "trattament", "modulo meteo", "non attivo", "non e attivo"],
