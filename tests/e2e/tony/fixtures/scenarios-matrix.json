        "usedGemini": false,
        "responseMustMatch": ["tariff"],
        "navigation": { "urlIncludes": "tariffe-standalone" }
      }
    },
    {
      "id": "T-PERF-003",
      "status": "ready",
      "mode": "explore",
      "tier": 3,
      "category": "perf",
      "description": "Live CF — quante tariffe attive ho? (binario A quick reply)",
      "contract": {
        "invariant": "Domanda analitica tariffe → risposta coerente con dati seed (no sessione scaduta)",
        "primaryAsserts": ["responseMustMatchGroups o gruppi semantici", "responseMustNotMatch errori auth"],
        "avoidAsserts": ["testo byte-identico Gemini"]
      },
      "persona": "manager",
      "templateIncludes": "conto-terzi",
      "startUrl": "/modules/conto-terzi/views/tariffe-standalone.html?emulator=1&tonyE2e=1&tonyE2eLive=1",
      "login": "loginAsManagerContoTerzi",
      "messages": ["quante tariffe attive ho?"],
