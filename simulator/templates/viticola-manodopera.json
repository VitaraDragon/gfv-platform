{
  "templateId": "viticola-manodopera",
  "descrizione": "Azienda viticola con manodopera: manager + caposquadra + operai, flusso lavori/ore/validazioni multi-persona",
  "extends": "solo-titolare-viticola",
  "piano": "base",
  "moduli": ["vigneto", "parcoMacchine", "magazzino", "manodopera"],
  "quantities": {
    "terreni": 4,
    "trattori": 1,
    "attrezzi": 3,
    "flotta": 2,
    "vigneti": 4,
    "prodotti": 5,
    "attivitaGiorniLavorativi": 20,
    "potatureVigneto": 4,
    "trattamentiVigneto": 12,
    "manager": 1,
    "caposquadra": 1,
    "operai": 3,
    "squadre": 1,
    "lavoriSquadra": 2,
    "lavoriAutonomi": 1,
    "giorniOreSimulate": 10
  },
  "personas": {
    "provision": "pre_created",
    "skipInviteFlow": true,
    "roles": ["amministratore", "caposquadra", "operaio"],
    "emailPattern": "sim+{slug}_{role}{index}@gfv.local"
  },
  "distribution": {
    "operaiPerSquadra": "round_robin",
    "squadreDefaultEqualsCaposquadra": true
  },
  "manodopera": {
    "orarioInizio": "07:30",
    "orarioFine": "12:00",
    "pauseMinuti": 30,
    "comunicazioniSquadra": true,
    "confermeOperai": true,
    "assenzaMalattia": true,
    "standbyAssenzaMalattia": true
  }
}
