{
  "name": "gfv-platform",
  "version": "1.0.0",
  "description": "GFV Platform - SaaS multi-tenant per gestione aziende agricole",
  "type": "module",
  "scripts": {
    "build:landing": "cd landing && npm install && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "start": "http-server -p 8000 -c-1",
    "deploy:landing": "npm run build:landing && node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only hosting",
    "deploy:functions": "node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only functions",
    "deploy:rules": "node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only firestore:rules,firestore:indexes",
    "deploy:firebase": "node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only functions,firestore:rules,firestore:indexes",
    "sync:functions-secrets": "powershell -ExecutionPolicy Bypass -File scripts/sync-functions-secrets.ps1",
    "sync:functions-secrets:deploy": "powershell -ExecutionPolicy Bypass -File scripts/sync-functions-secrets.ps1 -Deploy",
    "deploy:hosting": "node ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only hosting",
    "generate:tony-routes": "node scripts/generate-tony-routes.cjs",
    "bump:pwa-cache": "node scripts/bump-pwa-cache-version.mjs",
    "setup:hooks": "git config core.hooksPath .githooks",
    "guida:impact": "node scripts/guida-impact.mjs",
    "guida:suggest": "node scripts/guida-suggest-prompt.mjs",
    "tony:perf-review": "node scripts/tony-perf-log-review.mjs",
    "dashboard:perf-smoke": "vitest run tests/dashboard-perf-slo.test.js",
    "tony:canary": "node scripts/tony-connectivity-canary.mjs",
    "tony:tts-canary": "node scripts/tony-tts-canary.mjs",
    "sim:emulators": "node ./node_modules/firebase-tools/lib/bin/firebase.js emulators:start --only auth,firestore",
    "sim:smoke": "node simulator/smoke-test.js",
    "sim:run": "node simulator/orchestrator.js",
    "sim:run:batch": "node simulator/run-batch.js",
    "sim:run:demo-max": "node simulator/run-demo-max.js",
    "sim:run:verbose": "node simulator/orchestrator.js --verbose",
    "sim:setup": "node simulator/orchestrator.js --setup-only",
    "sim:inspect": "node simulator/inspect-tenant.js",
    "sim:audit": "node simulator/audit-manifest.js",
    "sim:migrate-terreni": "node simulator/migrate-terreni-seed.js",
    "sim:cleanup": "node simulator/cleanup.js",
    "sim:refresh-dates": "node simulator/refresh-dates.js",
    "sim:backfill": "node simulator/backfill-existing.js",
    "sim:verify-spese": "node simulator/verify-spese.js",
    "sim:test": "node simulator/integration-test.js",
    "sim:test:vitest": "vitest run tests/simulator/ --no-file-parallelism",
    "sim:verify:e2e-seed": "node simulator/verify-e2e-seed.js",
    "sim:test:ci": "node simulator/ci-run.js",
    "sim:e2e": "node scripts/sim-e2e-run.mjs",
    "sim:e2e:write-p2": "node scripts/sim-e2e-run.mjs --only=operai-write,squadre-write,scadenze-write",
    "sim:e2e:pw": "playwright test",
    "sim:e2e:ui": "playwright test --ui",
    "sim:e2e:install": "playwright install --with-deps chromium",
    "sim:e2e:ci": "node simulator/ci-e2e-run.js",
    "sim:tony:e2e": "node scripts/sim-tony-e2e-run.mjs",
    "sim:tony:e2e:ci": "node simulator/ci-tony-e2e-run.js",
    "sim:tony:vitest": "node scripts/sim-tony-vitest-run.mjs"
  },
  "keywords": [
    "agriculture",
    "saas",
    "firebase",
    "multi-tenant"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitest/ui": "^1.0.0",
    "firebase-tools": "^15.19.1",
    "http-server": "^14.1.1",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0"
  }
}
