{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {"rules": "storage.rules"},
  "functions": {"source": "functions"},
  "hosting": {
    "target": "default",
    "public": "landing/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "**/functions/**", "**/docs-sviluppo/**", "**/documentazione-utente/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
