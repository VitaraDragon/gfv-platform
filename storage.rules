rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper: verifica autenticazione
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: verifica che l'utente appartenga al tenant
    function belongsToTenant(tenantId) {
      return isAuthenticated() && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }
    
    // Regola per loghi aziendali: tenants/{tenantId}/logo_*.{ext}
    match /tenants/{tenantId}/{logoFileName} {
      // Verifica che il file sia un logo (nome inizia con "logo_")
      function isLogoFile() {
        return logoFileName.matches('logo_.*');
      }
      
      // Lettura: utenti autenticati del tenant
      allow read: if isAuthenticated() && belongsToTenant(tenantId);
      
      // Scrittura: solo utenti autenticati del tenant (Manager/Amministratore verificato lato client)
      allow write: if isAuthenticated() && 
                      belongsToTenant(tenantId) &&
                      isLogoFile() &&
                      request.resource.size < 2 * 1024 * 1024 && // Max 2MB
                      request.resource.contentType.matches('image/.*'); // Solo immagini
      
      // Eliminazione: utenti autenticati del tenant
      allow delete: if isAuthenticated() && belongsToTenant(tenantId);
    }

    // Tony Occhi — originali documenti acquisiti (foto/PDF)
    // Path: tenants/{tenantId}/documentiAcquisiti/{sessionId}/page-N.ext
    match /tenants/{tenantId}/documentiAcquisiti/{sessionId}/{fileName} {
      function isDocumentPageFile() {
        return fileName.matches('page-[0-9]+\\.(jpg|jpeg|png|webp|pdf)');
      }
      function isAllowedDocContentType() {
        return request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf';
      }

      allow read: if isAuthenticated() && belongsToTenant(tenantId);

      allow create, update: if isAuthenticated()
        && belongsToTenant(tenantId)
        && isDocumentPageFile()
        && isAllowedDocContentType()
        && request.resource.size < 12 * 1024 * 1024;

      allow delete: if isAuthenticated() && belongsToTenant(tenantId);
    }
    
    // Blocca tutto il resto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}







